@model Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="page-header">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h1 class="page-title">Delete Category</h1>
            <p class="page-subtitle">Review the category information before removing it.</p>
        </div>
        <div>
            <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="surface-card">
    <div class="section-header">
        <h5 class="mb-0 fw-bold text-danger">Delete Confirmation</h5>
    </div>

    <div class="section-body">
        <form method="POST">
            <input asp-for="Id" hidden />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label">Category Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter category name" disabled />
                </div>

                <div class="col-md-6">
                    <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                    <input asp-for="DisplayOrder" class="form-control" placeholder="Enter display order" disabled />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" id="submitBtn" class="btn btn-danger">
                    <i class="bi bi-trash-fill me-2"></i>Delete
                </button>

                <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>