@{
    ViewData["Title"] = "Home Page";
}

@model IEnumerable<Product>

<div class="container py-5">
    <div class="row pb-3">
        @foreach (var product in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card border-0 p-3 shadow-sm h-100 rounded-4">

                    <!-- Image -->
                    <div class="text-center mb-3">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/no-image.png" : product.ImageUrl)"
                             class="card-img-top rounded"
                             style="height: 300px; object-fit: cover;"
                             alt="@product.Title" />
                    </div>

                    <!-- Content -->
                    <div class="card-body d-flex flex-column p-0">

                        <!-- Title -->
                        <h5 class="card-title text-dark fw-bold mb-1">
                            @product.Title
                        </h5>

                        <!-- Author -->
                        <p class="text-muted mb-2">
                            by <span class="fw-semibold">@product.Author</span>
                        </p>

                        <!-- Price Section -->
                        <div class="mb-3">
                            <span class="text-danger fw-bold fs-5 me-2">
                                @product.Price.ToString("C")
                            </span>

                            <span class="text-muted text-decoration-line-through">
                                @product.ListPrice.ToString("C")
                            </span>
                        </div>

                        <!-- Optional Discount Badge -->
                        @{
                            var discount = product.ListPrice > 0
                                ? (int)(((product.ListPrice - product.Price) / product.ListPrice) * 100)
                                : 0;
                        }

                        @if (discount > 0)
                        {
                            <span class="badge bg-success mb-3">
                                @discount% OFF
                            </span>
                        }

                        <!-- Button -->
                        <a asp-action="Details" asp-route-productId="@product.Id"
                               class="btn btn-outline-primary mt-auto w-100 rounded-pill">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>