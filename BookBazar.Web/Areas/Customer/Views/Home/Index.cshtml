@{
    ViewData["Title"] = "Home Page";
}

@model IEnumerable<Product>

<div class="page-header">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
        <div>
            <h1 class="page-title">Discover Your Next Read</h1>
            <p class="page-subtitle">Browse our collection of books with clean pricing and simple details.</p>
        </div>
        <div>
            <span class="soft-badge-neutral">
                <i class="bi bi-journal-text me-2"></i>Book Collection
            </span>
        </div>
    </div>
</div>

<div class="row g-4">
    @foreach (var product in Model)
    {
        var discount = product.ListPrice > 0
            ? (int)(((product.ListPrice - product.Price) / product.ListPrice) * 100)
            : 0;

        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
            <a asp-action="Details"
                   asp-route-productId="@product.Id"
                   class="book-card-link">

                <div class="book-card p-3 h-100">
                    <div class="book-card-image-wrap mb-3">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/no-image.png" : product.ImageUrl)"
                             class="book-card-image"
                             alt="@product.Title" />
                    </div>

                    <div class="book-card-content">
                        <h5 class="book-title mb-1">@product.Title</h5>

                        <p class="book-author mb-3">
                            by <span class="fw-semibold text-dark">@product.Author</span>
                        </p>

                        <div class="mb-3">
                            <div class="d-flex align-items-center flex-wrap gap-2">
                                <span class="price-current">@product.Price.ToString("C")</span>
                                <span class="price-old">@product.ListPrice.ToString("C")</span>
                            </div>
                        </div>

                        <div class="book-badge-wrap">
                            @if (discount > 0)
                            {
                                <span class="soft-badge">
                                    <i class="bi bi-tag me-2"></i>@discount% OFF
                                </span>
                            }
                            else
                            {
                                <span class="soft-badge-neutral">
                                    <i class="bi bi-bookmark me-2"></i>Available
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>