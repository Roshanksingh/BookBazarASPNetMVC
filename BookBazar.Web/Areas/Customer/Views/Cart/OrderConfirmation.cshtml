@model int

@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container py-5">
    <div class="page-header">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <span class="soft-badge mb-3">
                    <i class="bi bi-check-circle me-2"></i>Order Placed Successfully
                </span>
                <h1 class="page-title">Thank you for your order</h1>
                <p class="page-subtitle">
                    Your order has been confirmed and is now being processed.
                </p>
            </div>

            <div class="text-lg-end">
                <div class="soft-badge-neutral">
                    <i class="bi bi-receipt me-2"></i>Order Number: #@Model
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Side -->
        <div class="col-lg-8">
            <div class="surface-card h-100">
                <div class="section-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h5 class="mb-1 fw-bold text-dark">Order Confirmation</h5>
                        <p class="page-subtitle mb-0">
                            We’ve received your order and will begin processing it shortly.
                        </p>
                    </div>
                    <span class="soft-badge">
                        <i class="bi bi-patch-check me-2"></i>Confirmed
                    </span>
                </div>

                <div class="section-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="surface-card-sm h-100">
                                <div class="section-body">
                                    <h6 class="fw-bold mb-3 text-dark">
                                        <i class="bi bi-truck me-2"></i>Shipping Update
                                    </h6>
                                    <p class="text-secondary mb-2">
                                        Your books will be packed and shipped soon.
                                    </p>
                                    <p class="mb-0 text-secondary">
                                        Estimated arrival:
                                        <span class="fw-semibold text-dark">
                                            7 to 15 days from today
                                        </span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="surface-card-sm h-100">
                                <div class="section-body">
                                    <h6 class="fw-bold mb-3 text-dark">
                                        <i class="bi bi-envelope-check me-2"></i>Email Confirmation
                                    </h6>
                                    <p class="text-secondary mb-0">
                                        A confirmation email with your order details will be sent to your registered email address.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="surface-card-sm">
                                <div class="section-body">
                                    <h6 class="fw-bold mb-3 text-dark">
                                        <i class="bi bi-info-circle me-2"></i>What happens next?
                                    </h6>

                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <div class="p-3 rounded-4 border h-100" style="border-color:#e2e8f0 !important;">
                                                <div class="mb-2">
                                                    <span class="soft-badge-neutral">
                                                        <i class="bi bi-1-circle me-2"></i>Step 1
                                                    </span>
                                                </div>
                                                <h6 class="fw-semibold text-dark mb-2">Order Review</h6>
                                                <p class="text-secondary mb-0 small">
                                                    We verify your order details and prepare the items.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <div class="p-3 rounded-4 border h-100" style="border-color:#e2e8f0 !important;">
                                                <div class="mb-2">
                                                    <span class="soft-badge-neutral">
                                                        <i class="bi bi-2-circle me-2"></i>Step 2
                                                    </span>
                                                </div>
                                                <h6 class="fw-semibold text-dark mb-2">Packaging</h6>
                                                <p class="text-secondary mb-0 small">
                                                    Your books are securely packed to ensure safe delivery.
                                                </p>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <div class="p-3 rounded-4 border h-100" style="border-color:#e2e8f0 !important;">
                                                <div class="mb-2">
                                                    <span class="soft-badge-neutral">
                                                        <i class="bi bi-3-circle me-2"></i>Step 3
                                                    </span>
                                                </div>
                                                <h6 class="fw-semibold text-dark mb-2">Delivery</h6>
                                                <p class="text-secondary mb-0 small">
                                                    Your order will arrive at your shipping address within the estimated timeframe.
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex flex-wrap gap-2">
                                <a asp-area="Customer"
                                       asp-controller="Home"
                                       asp-action="Index"
                                       class="btn btn-primary">
                                    <i class="bi bi-house-door me-2"></i>Continue Shopping
                                </a>

                                <a asp-area="Customer"
                                       asp-controller="Order"
                                       asp-action="Index"
                                       class="btn btn-outline-secondary">
                                    <i class="bi bi-bag-check me-2"></i>View My Orders
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side -->
        <div class="col-lg-4">
            <div class="surface-card mb-4">
                <div class="section-header">
                    <h5 class="mb-1 fw-bold text-dark">Order Summary</h5>
                    <p class="page-subtitle mb-0">Quick overview of your purchase</p>
                </div>
                <div class="section-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-secondary">Order Number</span>
                        <span class="fw-semibold text-dark">#@Model</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-secondary">Order Date</span>
                        <span class="fw-semibold text-dark">@DateTime.Now.ToString("MMMM dd, yyyy")</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-secondary">Payment Status</span>
                        <span class="soft-badge-neutral">
                            <i class="bi bi-credit-card me-2"></i>Approved
                        </span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary">Shipping</span>
                        <span class="soft-badge">
                            <i class="bi bi-truck me-2"></i>Processing
                        </span>
                    </div>
                </div>
            </div>

            <div class="surface-card">
                <div class="section-header">
                    <h5 class="mb-1 fw-bold text-dark">Need Help?</h5>
                    <p class="page-subtitle mb-0">We’re here if you need support</p>
                </div>
                <div class="section-body">
                    <p class="text-secondary mb-3">
                        If you have any questions about your order, shipping, or payment, please contact our support team.
                    </p>

                    <div class="d-grid">
                        <a href="mailto:support@bookbazar.com" class="btn btn-outline-primary">
                            <i class="bi bi-envelope me-2"></i>Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>