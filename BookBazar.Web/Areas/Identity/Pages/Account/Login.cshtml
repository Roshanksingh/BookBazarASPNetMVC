@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
        <div class="page-header text-center text-lg-start">
            <h1 class="page-title">Welcome Back</h1>
            <p class="page-subtitle">Sign in to continue managing your books with a clean and simple experience.</p>
        </div>

        <div class="row g-4 align-items-stretch">
            <div class="col-lg-7">
                <div class="surface-card h-100">
                    <div class="section-header">
                        <h5 class="mb-0 fw-bold">Login</h5>
                    </div>

                    <div class="section-body">
                        <form id="account" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                            <div class="row g-3">
                                <div class="col-12">
                                    <label asp-for="Input.Email" class="form-label"></label>
                                    <input asp-for="Input.Email"
                                           class="form-control"
                                           autocomplete="username"
                                           aria-required="true"
                                           placeholder="name@example.com" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Input.Password" class="form-label"></label>
                                    <input asp-for="Input.Password"
                                           class="form-control"
                                           autocomplete="current-password"
                                           aria-required="true"
                                           placeholder="Enter password" />
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <div class="form-check mt-1">
                                        <input class="form-check-input" asp-for="Input.RememberMe" />
                                        <label asp-for="Input.RememberMe" class="form-check-label text-muted">
                                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid mt-4">
                                <button id="login-submit" type="submit" class="btn btn-primary">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Log in
                                </button>
                            </div>

                            <div class="d-flex flex-column gap-2 mt-4 auth-links">
                                <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none">
                                    Forgot your password?
                                </a>
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none">
                                    Register as a new user
                                </a>
                                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-decoration-none">
                                    Resend email confirmation
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="surface-card h-100">
                    <div class="section-header">
                        <h5 class="mb-0 fw-bold">External Access</h5>
                    </div>

                    <div class="section-body">
                        @{
                            if ((Model.ExternalLogins?.Count ?? 0) == 0)
                            {
                                <div class="empty-state text-start p-0">
                                    <div class="soft-badge-neutral mb-3">
                                        <i class="bi bi-info-circle me-2"></i>No External Providers
                                    </div>

                                    <p class="text-muted mb-0">
                                        There are no external authentication services configured at the moment.
                                    </p>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-3">
                                    Use another service to sign in to your account.
                                </p>

                                <form id="external-account"
                                      asp-page="./ExternalLogin"
                                      asp-route-returnUrl="@Model.ReturnUrl"
                                      method="post">
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit"
                                                    class="btn btn-outline-secondary w-100"
                                                    name="provider"
                                                    value="@provider.Name"
                                                    title="Log in using your @provider.DisplayName account">
                                                <i class="bi bi-box-arrow-in-right me-2"></i>@provider.DisplayName
                                            </button>
                                        }
                                    </div>
                                </form>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <span class="text-muted">Don’t have an account?</span>
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold text-decoration-none ms-1">
                Create one
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}